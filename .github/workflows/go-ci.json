{
   "jobs": {
      "test": {
         "runs-on": "ubuntu-latest",
         "steps": [
            {
               "uses": "actions/checkout@v4"
            },
            {
               "uses": "actions/setup-go@v2",
               "with": {
                  "go-version": "1.23"
               }
            },
            {
               "run": "go mod download"
            },
            {
               "run": "go test ./..."
            },
            {
               "uses": "gwatts/go-coverage-action@v2",
               "with": {
                  "coverage-threshold": 80
               }
            }
         ]
      }
   },
   "on": {
      "push": {
         "branches": [
            "main"
         ],
         "permissions": {
            "contents": "write",
            "id-token": "write"
         }
      }
   }
}
